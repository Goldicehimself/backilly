generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
//--ENUMS--
enum orderStatus{
  pending
  out_for_delivery
  delivered
  cancelled
}
//--MODELS--
model order{
  orderId          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId          String @db.Uuid
  owner            User   @relation(fields: [ownerId], references: [userId])
  orderItems       Item[]
  totalPrice       Decimal
  paymentStatus    String
  paymentMethod    String
  deliveryAddress  String
  deliveryPhone    String
  paidAt           DateTime
  isPaid           Boolean @default(false)
  paymentReference   String
  paystackAccessCode String
  status           orderStatus @default(pending)
  deliveryStatus     orderStatus @default(pending)
  
@@index([ownerId])
@@index([ownerId, status])
}

model User {
  userId String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orders order[]
}

model Item {
  itemId String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId String @db.Uuid
  order order @relation(fields: [orderId], references: [orderId])
}


